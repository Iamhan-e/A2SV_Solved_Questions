class Solution:
    def partitionLabels(self, s: str) -> List[int]:
        last_indx= {}
        
        for i, char in enumerate(s):
            last_indx[char] = i
        
        result = []
        start = 0
        end = 0
        
        for i, char in enumerate(s):
            end = max(end, last_indx[char])
            
            if i == end:
                result.append(end - start + 1)
                start = i + 1
        
        return result